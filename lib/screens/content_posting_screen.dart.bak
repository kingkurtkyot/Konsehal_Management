  // ─── SHARED HELPERS ───────────────────────────────────────────────────────

  Widget _buildSealImage(double size) {
    return ClipOval(
      child: Image.asset('assets/seal.png', width: size, height: size, fit: BoxFit.cover,
        errorBuilder: (context, error, stackTrace) => Container(
          width: size, height: size,
          decoration: BoxDecoration(shape: BoxShape.circle, color: const Color(0xFF1B5E20).withValues(alpha: 0.1)),
          child: Center(child: Text('🇵🇭', style: TextStyle(fontSize: size * 0.5))),
        ),
      ),
    );
  }

  Widget _buildFooterBranding({required bool dark}) {
    final color = dark ? const Color(0xFF1B5E20) : Colors.white;
    return Row(
      children: [
        Icon(Icons.facebook, color: color, size: 22),
        const SizedBox(width: 8),
        Text('Konsehal Matthew Lagaya',
          style: GoogleFonts.poppins(fontSize: 12, fontWeight: FontWeight.w700, color: color)),
      ],
    );
  }

  Widget _buildCalendarTab() {
    final dailyEvents = _getEventsForDay(_selectedDay!);

    return Column(
      children: [
        TableCalendar<ScheduledPost>(
          firstDay: DateTime.now().subtract(const Duration(days: 365)),
          lastDay: DateTime.now().add(const Duration(days: 365)),
          focusedDay: _focusedDay,
          selectedDayPredicate: (day) => isSameDay(_selectedDay, day),
          calendarFormat: CalendarFormat.month,
          eventLoader: _getEventsForDay,
          startingDayOfWeek: StartingDayOfWeek.monday,
          headerStyle: HeaderStyle(
            formatButtonVisible: false,
            titleCentered: true,
            titleTextStyle: GoogleFonts.poppins(fontWeight: FontWeight.w700, fontSize: 16),
          ),
          calendarStyle: CalendarStyle(
            selectedDecoration: const BoxDecoration(color: Color(0xFF1B5E20), shape: BoxShape.circle),
            todayDecoration: BoxDecoration(color: const Color(0xFF1B5E20).withValues(alpha: 0.4), shape: BoxShape.circle),
            markerDecoration: const BoxDecoration(color: Color(0xFFE67E22), shape: BoxShape.circle),
          ),
          onDaySelected: (selectedDay, focusedDay) {
            setState(() {
              _selectedDay = selectedDay;
              _focusedDay = focusedDay;
            });
          },
        ),
        const Divider(),
        Expanded(
          child: dailyEvents.isEmpty
              ? Center(
                  child: Text(
                    'No posts scheduled for this date.',
                    style: GoogleFonts.poppins(color: Colors.grey.shade600),
                  ),
                )
              : ListView.builder(
                  padding: const EdgeInsets.all(16),
                  itemCount: dailyEvents.length,
                  itemBuilder: (context, index) {
                    final post = dailyEvents[index];
                    return Card(
                      margin: const EdgeInsets.only(bottom: 16),
                      clipBehavior: Clip.antiAlias,
                      shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(12)),
                      child: Column(
                        children: [
                          Image.file(File(post.imagePath), fit: BoxFit.cover),
                          Container(
                            padding: const EdgeInsets.all(12),
                            color: Colors.white,
                            child: Row(
                              children: [
                                Text(
                                  DateFormat('EEEE, MMM d').format(post.scheduledDate),
                                  style: GoogleFonts.poppins(fontWeight: FontWeight.w600, color: const Color(0xFF1B5E20)),
                                ),
                                const Spacer(),
                                IconButton(
                                  icon: const Icon(Icons.share, color: Color(0xFF6C3483)),
                                  onPressed: () {
                                    Share.shareXFiles([XFile(post.imagePath)], text: '#SerbisyongTapatparasaLahat');
                                  },
                                ),
                                IconButton(
                                  icon: const Icon(Icons.delete, color: Colors.red),
                                  onPressed: () async {
                                    await StorageService.deleteScheduledPost(post.id);
                                    try { await File(post.imagePath).delete(); } catch (_) {}
                                    await _loadScheduledPosts();
                                  },
                                ),
                              ],
                            ),
                          ),
                        ],
                      ),
                    );
                  },
                ),
        ),
      ],
    );
  }
}

// ═══════════════════════════════════════════════════════════════════════════════
// CUSTOM PAINTERS — Stunning backgrounds and textures
// ═══════════════════════════════════════════════════════════════════════════════

/// Faint grid paper background
class _GridPainter extends CustomPainter {
  @override
  void paint(Canvas canvas, Size size) {
    final paint = Paint()..color = const Color(0xFFE0E0E0)..strokeWidth = 0.5;
    const space = 28.0;
    for (double i = 0; i < size.width; i += space) {
      canvas.drawLine(Offset(i, 0), Offset(i, size.height), paint);
    }
    for (double i = 0; i < size.height; i += space) {
      canvas.drawLine(Offset(0, i), Offset(size.width, i), paint);
    }
  }
  @override
  bool shouldRepaint(CustomPainter oldDelegate) => false;
}

/// Subtle paper texture dots
class _PaperTexturePainter extends CustomPainter {
  @override
  void paint(Canvas canvas, Size size) {
    final rng = Random(42); // Fixed seed for consistent texture
    final paint = Paint()..color = const Color(0xFF8B7355).withValues(alpha: 0.04);
    for (int i = 0; i < 200; i++) {
      canvas.drawCircle(
        Offset(rng.nextDouble() * size.width, rng.nextDouble() * size.height),
        rng.nextDouble() * 2 + 0.5,
        paint,
      );
    }
  }
  @override
  bool shouldRepaint(CustomPainter oldDelegate) => false;
}

/// Diamond/rhombus pattern for modern DYK variant
class _DiamondPatternPainter extends CustomPainter {
  @override
  void paint(Canvas canvas, Size size) {
    final paint = Paint()
      ..color = const Color(0xFF1B5E20).withValues(alpha: 0.025)
      ..style = PaintingStyle.stroke
      ..strokeWidth = 1.0;
    const spacing = 40.0;
    for (double x = 0; x < size.width + spacing; x += spacing) {
      for (double y = 0; y < size.height + spacing; y += spacing) {
        final path = Path()
          ..moveTo(x, y - 10)
          ..lineTo(x + 10, y)
          ..lineTo(x, y + 10)
          ..lineTo(x - 10, y)
          ..close();
        canvas.drawPath(path, paint);
      }
    }
  }
  @override
  bool shouldRepaint(CustomPainter oldDelegate) => false;
}

/// Diagonal green block for quote variant
class _DiagonalPainter extends CustomPainter {
  @override
  void paint(Canvas canvas, Size size) {
    final paint = Paint()..color = const Color(0xFF1B5E20);
    final path = Path()
      ..moveTo(0, size.height * 0.7)
      ..lineTo(size.width, size.height * 0.45)
      ..lineTo(size.width, size.height)
      ..lineTo(0, size.height)
      ..close();
    canvas.drawPath(path, paint);
  }
  @override
  bool shouldRepaint(CustomPainter oldDelegate) => false;
}

/// Bokeh circles for Bible dark gradient
class _BokehPainter extends CustomPainter {
  @override
  void paint(Canvas canvas, Size size) {
    final rng = Random(123);
    for (int i = 0; i < 12; i++) {
      final x = rng.nextDouble() * size.width;
      final y = rng.nextDouble() * size.height;
      final r = rng.nextDouble() * 40 + 15;
      final paint = Paint()
        ..color = Colors.white.withValues(alpha: rng.nextDouble() * 0.04 + 0.01)
        ..style = PaintingStyle.fill;
      canvas.drawCircle(Offset(x, y), r, paint);
    }
  }
  @override
  bool shouldRepaint(CustomPainter oldDelegate) => false;
}

/// Soft vignette edges for parchment Bible variant
class _VignettePainter extends CustomPainter {
  @override
  void paint(Canvas canvas, Size size) {
    final rect = Rect.fromLTWH(0, 0, size.width, size.height);
    final paint = Paint()
      ..shader = RadialGradient(
        center: Alignment.center,
        radius: 0.85,
        colors: [Colors.transparent, const Color(0xFF8B7355).withValues(alpha: 0.08)],
      ).createShader(rect);
    canvas.drawRect(rect, paint);
  }
  @override
  bool shouldRepaint(CustomPainter oldDelegate) => false;
}

