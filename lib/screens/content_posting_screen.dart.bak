  /// Builds individual neon green text lines with dark green background
  List<Widget> _buildNeonLines(String text) {
    // Split into ~4-5 word chunks for a visually stacked effect
    final words = text.split(' ');
    final lines = <String>[];
    var current = '';
    for (final word in words) {
      if (current.isEmpty) {
        current = word;
      } else if ('$current $word'.length < 28) {
        current = '$current $word';
      } else {
        lines.add(current);
        current = word;
      }
    }
    if (current.isNotEmpty) lines.add(current);

    return lines.map((line) => Padding(
      padding: const EdgeInsets.only(bottom: 3),
      child: Container(
        padding: const EdgeInsets.symmetric(horizontal: 14, vertical: 6),
        color: const Color(0xFF14432A),
        child: Text(
          '\u201C$line\u201D',
          style: GoogleFonts.inter(fontSize: 20, fontWeight: FontWeight.w800, color: const Color(0xFF00E676), height: 1.2),
        ),
      ),
    )).toList();
  }

